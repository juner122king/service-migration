# Connection
TARGET_HOST=203.0.113.10
TARGET_USER=juner122king
TARGET_SSH_PORT=22
TARGET_HOME=/home/juner122king
SSH_EXTRA_OPTS=

# Target runtime user for CPA Dashboard systemd unit.
SERVICE_USER=juner122king
SERVICE_GROUP=juner122king

# Sync scope
SYNC_CLIPROXY=1
SYNC_NEWAPI=1
SYNC_CPA_DASHBOARD=1
SYNC_SING_BOX=1

# By default only sync config and data required to recover services.
INCLUDE_LOGS=0
INCLUDE_GIT_DIRS=0

# Restart behavior after target install.
ENABLE_SERVICES=1
START_SERVICES=1

# Optional firewall command executed on target after install.
# Example: sudo ufw allow 8317/tcp
TARGET_POST_INSTALL=
